# ─────────────────────────────────────────────────────────────────────────────
# ProChauffeur Web — environment variables
# Copy to .env.local for local dev. In Vercel, add these under Project Settings →
# Environment Variables. NEXT_PUBLIC_* values are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase Web app config (Project settings → General → Your apps → SDK config)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Realtime Database URL (for live driver locations on Dispatch)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Mapbox access token (URL-restrict it in the Mapbox dashboard)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Locale defaults (Australia)
NEXT_PUBLIC_DEFAULT_LOCALE=en-AU
NEXT_PUBLIC_DEFAULT_CURRENCY=AUD
NEXT_PUBLIC_DEFAULT_TIMEZONE=Australia/Sydney
NEXT_PUBLIC_FUNCTIONS_REGION=us-central1

# ── Server-only secrets (DO NOT prefix with NEXT_PUBLIC) ─────────────────────
# Firebase Admin service account JSON, base64-encoded:
#   cat service-account.json | base64    (macOS/Linux)
FIREBASE_SERVICE_ACCOUNT_KEY=
